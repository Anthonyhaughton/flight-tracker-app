# Copy to .env and fill in. Never commit the real .env (see .gitignore).

# seats.aero Pro Partner API key -- https://seats.aero/ account settings,
# after subscribing to a Pro plan with Partner API access enabled.
SEATS_AERO_API_KEY=

# Discord webhook URL -- default v1.0 notifier (see watchlist.yaml's
# `notifier` key). Server Settings -> Integrations -> Webhooks -> New
# Webhook -> Copy Webhook URL.
DISCORD_WEBHOOK_URL=

# Telegram bot token -- alternate notifier, not used unless watchlist.yaml's
# `notifier: telegram`. Message @BotFather on Telegram, run /newbot.
TELEGRAM_BOT_TOKEN=

# Telegram chat id alerts get sent to -- message your bot once, then call
# https://api.telegram.org/bot<token>/getUpdates to read your chat id back.
TELEGRAM_CHAT_ID=

# SerpApi key for Google Flights cash fares -- https://serpapi.com/ dashboard.
# Not read by any code yet; v1.0 is award-only. Needed starting v1.1.
SERPAPI_KEY=

# AWS region the Lambda/DynamoDB/SSM resources deploy into. Used by deploy
# tooling only -- not required to run the local pytest suite.
AWS_REGION=us-east-1
